{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-runtime-sidecar",
  "description": "允许主窗口启动、控制并终止打包的 Mimodex Runtime sidecar。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "process:allow-restart",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/mimodex-runtime",
          "sidecar": true
        },
        {
          "name": "embedded-pwsh",
          "cmd": "pwsh.exe",
          "args": ["-NoLogo", "-NoProfile", "-NoExit"]
        },
        {
          "name": "embedded-powershell",
          "cmd": "powershell.exe",
          "args": ["-NoLogo", "-NoProfile", "-NoExit"]
        }
      ]
    }
  ]
}
