+use super::*;
+use crate::AdditionalProperties;
+use crate::ResponsesApiNamespace;
+use crate::ResponsesApiTool;
+use pretty_assertions::assert_eq;
+use serde_json::json;
+use std::collections::BTreeMap;
+
+fn function_tool() -> ToolSpec {
+    ToolSpec::Function(ResponsesApiTool {
+        name: "read_file".to_string(),
+        description: "Read a file".to_string(),
+        strict: false,
+        defer_loading: None,
+        parameters: JsonSchema::object(
+            BTreeMap::from([(
+                "path".to_string(),
+                JsonSchema::string(None).with_encrypted(),
+            )]),
+            Some(vec!["path".to_string()]),
+            Some(AdditionalProperties::Boolean(false)),
+        ),
+        output_schema: None,
+    })
+}
+
+#[test]
+fn encodes_function_tools_without_responses_only_fields() {
+    let tools = create_tools_for_chat_completions(&[function_tool()]).unwrap();
+
+    assert_eq!(
+        serde_json::to_value(tools).unwrap(),
+        json!([
+            {
+                "type": "function",
+                "function": {
+                    "name": "read_file",
+                    "description": "Read a file",
+                    "parameters": {
+                        "type": "object",
+                        "properties": {
+                            "path": {"type": "string"}
+                        },
+                        "required": ["path"],
+                        "additionalProperties": false
+                    }
+                }
+            }
+        ])
+    );
+}
+
+#[test]
+fn rejects_non_function_tools() {
+    let error = create_tools_for_chat_completions(&[ToolSpec::Namespace(ResponsesApiNamespace {
+        name: "workspace".to_string(),
+        description: "Workspace tools".to_string(),
+        tools: Vec::new(),
+    })])
+    .unwrap_err();
+
+    assert_eq!(
+        error,
+        ChatCompletionsToolEncodingError::UnsupportedToolType("namespace")
+    );
+}
