@@ -0,0 +1,226 @@
+use super::*;
+use codex_protocol::models::FunctionCallOutputPayload;
+use codex_protocol::models::ReasoningItemReasoningSummary;
+use pretty_assertions::assert_eq;
+use serde_json::json;
+
+fn message(role: &str, text: &str) -> ResponseItem {
+    ResponseItem::Message {
+        id: None,
+        role: role.to_string(),
+        content: vec![ContentItem::OutputText {
+            text: text.to_string(),
+        }],
+        phase: None,
+    }
+}
+
+fn reasoning(text: &str) -> ResponseItem {
+    ResponseItem::Reasoning {
+        id: String::new(),
+        summary: vec![ReasoningItemReasoningSummary::SummaryText {
+            text: "summary".to_string(),
+        }],
+        content: Some(vec![ReasoningItemContent::ReasoningText {
+            text: text.to_string(),
+        }]),
+        encrypted_content: None,
+    }
+}
+
+fn function_call(call_id: &str, name: &str, arguments: &str) -> ResponseItem {
+    ResponseItem::FunctionCall {
+        id: None,
+        name: name.to_string(),
+        namespace: None,
+        arguments: arguments.to_string(),
+        call_id: call_id.to_string(),
+    }
+}
+
+fn function_output(call_id: &str, output: &str) -> ResponseItem {
+    ResponseItem::FunctionCallOutput {
+        call_id: call_id.to_string(),
+        output: FunctionCallOutputPayload::from_text(output.to_string()),
+    }
+}
+
+#[test]
+fn encodes_system_user_and_reasoning_assistant_messages() {
+    let messages = encode_chat_messages(
+        "base instructions",
+        &[
+            message("developer", "workspace context"),
+            message("user", "hello"),
+            reasoning("think"),
+            message("assistant", "answer"),
+        ],
+    )
+    .unwrap();
+
+    assert_eq!(
+        serde_json::to_value(messages).unwrap(),
+        json!([
+            {"role": "system", "content": "base instructions"},
+            {"role": "system", "content": "workspace context"},
+            {"role": "user", "content": "hello"},
+            {
+                "role": "assistant",
+                "content": "answer",
+                "reasoning_content": "think"
+            }
+        ])
+    );
+}
+
+#[test]
+fn groups_parallel_tool_calls_and_preserves_call_ids() {
+    let messages = encode_chat_messages(
+        "",
+        &[
+            reasoning("inspect"),
+            function_call("call-1", "read_file", "{\"path\":\"a.rs\"}"),
+            function_call("call-2", "read_file", "{\"path\":\"b.rs\"}"),
+            function_output("call-1", "a"),
+            function_output("call-2", "b"),
+        ],
+    )
+    .unwrap();
+
+    assert_eq!(
+        serde_json::to_value(messages).unwrap(),
+        json!([
+            {
+                "role": "assistant",
+                "content": null,
+                "reasoning_content": "inspect",
+                "tool_calls": [
+                    {
+                        "id": "call-1",
+                        "type": "function",
+                        "function": {
+                            "name": "read_file",
+                            "arguments": "{\"path\":\"a.rs\"}"
+                        }
+                    },
+                    {
+                        "id": "call-2",
+                        "type": "function",
+                        "function": {
+                            "name": "read_file",
+                            "arguments": "{\"path\":\"b.rs\"}"
+                        }
+                    }
+                ]
+            },
+            {"role": "tool", "tool_call_id": "call-1", "content": "a"},
+            {"role": "tool", "tool_call_id": "call-2", "content": "b"}
+        ])
+    );
+}
+
+#[test]
+fn preserves_serial_tool_round_boundaries() {
+    let messages = encode_chat_messages(
+        "",
+        &[
+            reasoning("first"),
+            function_call("call-1", "read_file", "{\"path\":\"a.rs\"}"),
+            function_output("call-1", "a"),
+            reasoning("second"),
+            function_call("call-2", "read_file", "{\"path\":\"b.rs\"}"),
+            function_output("call-2", "b"),
+        ],
+    )
+    .unwrap();
+
+    assert_eq!(
+        serde_json::to_value(messages).unwrap(),
+        json!([
+            {
+                "role": "assistant",
+                "content": null,
+                "reasoning_content": "first",
+                "tool_calls": [{
+                    "id": "call-1",
+                    "type": "function",
+                    "function": {
+                        "name": "read_file",
+                        "arguments": "{\"path\":\"a.rs\"}"
+                    }
+                }]
+            },
+            {"role": "tool", "tool_call_id": "call-1", "content": "a"},
+            {
+                "role": "assistant",
+                "content": null,
+                "reasoning_content": "second",
+                "tool_calls": [{
+                    "id": "call-2",
+                    "type": "function",
+                    "function": {
+                        "name": "read_file",
+                        "arguments": "{\"path\":\"b.rs\"}"
+                    }
+                }]
+            },
+            {"role": "tool", "tool_call_id": "call-2", "content": "b"}
+        ])
+    );
+}
+
+#[test]
+fn rejects_reasoning_without_replayable_content() {
+    let error = encode_chat_messages(
+        "",
+        &[ResponseItem::Reasoning {
+            id: String::new(),
+            summary: Vec::new(),
+            content: None,
+            encrypted_content: Some("encrypted".to_string()),
+        }],
+    )
+    .unwrap_err();
+
+    assert_eq!(error, ChatCompletionsEncodingError::MissingReasoningContent);
+}
+
+#[test]
+fn rejects_unsupported_images_and_namespaced_tools() {
+    let image_error = encode_chat_messages(
+        "",
+        &[ResponseItem::Message {
+            id: None,
+            role: "user".to_string(),
+            content: vec![ContentItem::InputImage {
+                image_url: "data:image/png;base64,AA==".to_string(),
+                detail: None,
+            }],
+            phase: None,
+        }],
+    )
+    .unwrap_err();
+    assert_eq!(
+        image_error,
+        ChatCompletionsEncodingError::UnsupportedMessageContent {
+            role: "user".to_string(),
+            content_type: "image",
+        }
+    );
+
+    let namespaced_error = encode_chat_messages(
+        "",
+        &[ResponseItem::FunctionCall {
+            id: None,
+            name: "read_file".to_string(),
+            namespace: Some("workspace".to_string()),
+            arguments: "{}".to_string(),
+            call_id: "call-1".to_string(),
+        }],
+    )
+    .unwrap_err();
+    assert_eq!(
+        namespaced_error,
+        ChatCompletionsEncodingError::NamespacedFunctionCall("read_file".to_string())
+    );
+}
