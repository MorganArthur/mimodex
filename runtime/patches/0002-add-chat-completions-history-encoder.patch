+++ b/codex-rs/codex-api/src/chat_completions.rs
@@ -0,0 +1,235 @@
+use codex_protocol::models::ContentItem;
+use codex_protocol::models::FunctionCallOutputBody;
+use codex_protocol::models::ReasoningItemContent;
+use codex_protocol::models::ResponseItem;
+use serde::Serialize;
+use thiserror::Error;
+
+#[derive(Debug, Clone, Serialize, PartialEq, Eq)]
+#[serde(tag = "role", rename_all = "lowercase")]
+pub enum ChatMessage {
+    System {
+        content: String,
+    },
+    User {
+        content: String,
+    },
+    Assistant {
+        content: Option<String>,
+        #[serde(skip_serializing_if = "Option::is_none")]
+        reasoning_content: Option<String>,
+        #[serde(skip_serializing_if = "Vec::is_empty")]
+        tool_calls: Vec<ChatToolCall>,
+    },
+    Tool {
+        tool_call_id: String,
+        content: String,
+    },
+}
+
+#[derive(Debug, Clone, Serialize, PartialEq, Eq)]
+pub struct ChatToolCall {
+    pub id: String,
+    #[serde(rename = "type")]
+    pub kind: ChatToolCallType,
+    pub function: ChatFunctionCall,
+}
+
+#[derive(Debug, Clone, Copy, Serialize, PartialEq, Eq)]
+#[serde(rename_all = "lowercase")]
+pub enum ChatToolCallType {
+    Function,
+}
+
+#[derive(Debug, Clone, Serialize, PartialEq, Eq)]
+pub struct ChatFunctionCall {
+    pub name: String,
+    pub arguments: String,
+}
+
+#[derive(Debug, Error, PartialEq, Eq)]
+pub enum ChatCompletionsEncodingError {
+    #[error("unsupported chat message role: {0}")]
+    UnsupportedMessageRole(String),
+    #[error("chat completions does not support {content_type} content in {role} messages")]
+    UnsupportedMessageContent {
+        role: String,
+        content_type: &'static str,
+    },
+    #[error("reasoning item has no replayable reasoning content")]
+    MissingReasoningContent,
+    #[error("chat completions does not support namespaced function call: {0}")]
+    NamespacedFunctionCall(String),
+    #[error("chat completions does not support structured function output for call: {0}")]
+    StructuredFunctionOutput(String),
+    #[error("chat completions does not support response item: {0}")]
+    UnsupportedResponseItem(&'static str),
+}
+
+#[derive(Default)]
+struct PendingAssistant {
+    content: Vec<String>,
+    reasoning_content: Vec<String>,
+    tool_calls: Vec<ChatToolCall>,
+}
+
+impl PendingAssistant {
+    fn is_empty(&self) -> bool {
+        self.content.is_empty() && self.reasoning_content.is_empty() && self.tool_calls.is_empty()
+    }
+
+    fn flush_into(&mut self, messages: &mut Vec<ChatMessage>) {
+        if self.is_empty() {
+            return;
+        }
+
+        messages.push(ChatMessage::Assistant {
+            content: (!self.content.is_empty()).then(|| self.content.join("\n")),
+            reasoning_content: (!self.reasoning_content.is_empty())
+                .then(|| self.reasoning_content.concat()),
+            tool_calls: std::mem::take(&mut self.tool_calls),
+        });
+        self.content.clear();
+        self.reasoning_content.clear();
+    }
+}
+
+pub fn encode_chat_messages(
+    instructions: &str,
+    input: &[ResponseItem],
+) -> Result<Vec<ChatMessage>, ChatCompletionsEncodingError> {
+    let mut messages = Vec::new();
+    if !instructions.is_empty() {
+        messages.push(ChatMessage::System {
+            content: instructions.to_string(),
+        });
+    }
+
+    let mut pending_assistant = PendingAssistant::default();
+    for item in input {
+        match item {
+            ResponseItem::Reasoning { content, .. } => {
+                let reasoning_content = content
+                    .as_ref()
+                    .map(|items| {
+                        items
+                            .iter()
+                            .map(|item| match item {
+                                ReasoningItemContent::ReasoningText { text }
+                                | ReasoningItemContent::Text { text } => text.as_str(),
+                            })
+                            .collect::<String>()
+                    })
+                    .filter(|content| !content.is_empty())
+                    .ok_or(ChatCompletionsEncodingError::MissingReasoningContent)?;
+                pending_assistant.reasoning_content.push(reasoning_content);
+            }
+            ResponseItem::Message { role, content, .. } if role == "assistant" => {
+                pending_assistant
+                    .content
+                    .push(encode_message_content(role, content)?);
+            }
+            ResponseItem::FunctionCall {
+                name,
+                namespace,
+                arguments,
+                call_id,
+                ..
+            } => {
+                if namespace.is_some() {
+                    return Err(ChatCompletionsEncodingError::NamespacedFunctionCall(
+                        name.clone(),
+                    ));
+                }
+                pending_assistant.tool_calls.push(ChatToolCall {
+                    id: call_id.clone(),
+                    kind: ChatToolCallType::Function,
+                    function: ChatFunctionCall {
+                        name: name.clone(),
+                        arguments: arguments.clone(),
+                    },
+                });
+            }
+            ResponseItem::Message { role, content, .. }
+                if role == "user" || role == "system" || role == "developer" =>
+            {
+                pending_assistant.flush_into(&mut messages);
+                let content = encode_message_content(role, content)?;
+                if role == "user" {
+                    messages.push(ChatMessage::User { content });
+                } else {
+                    messages.push(ChatMessage::System { content });
+                }
+            }
+            ResponseItem::Message { role, .. } => {
+                return Err(ChatCompletionsEncodingError::UnsupportedMessageRole(
+                    role.clone(),
+                ));
+            }
+            ResponseItem::FunctionCallOutput { call_id, output } => {
+                pending_assistant.flush_into(&mut messages);
+                let FunctionCallOutputBody::Text(content) = &output.body else {
+                    return Err(ChatCompletionsEncodingError::StructuredFunctionOutput(
+                        call_id.clone(),
+                    ));
+                };
+                messages.push(ChatMessage::Tool {
+                    tool_call_id: call_id.clone(),
+                    content: content.clone(),
+                });
+            }
+            item => {
+                return Err(ChatCompletionsEncodingError::UnsupportedResponseItem(
+                    response_item_kind(item),
+                ));
+            }
+        }
+    }
+
+    pending_assistant.flush_into(&mut messages);
+    Ok(messages)
+}
+
+fn encode_message_content(
+    role: &str,
+    content: &[ContentItem],
+) -> Result<String, ChatCompletionsEncodingError> {
+    content
+        .iter()
+        .map(|item| match item {
+            ContentItem::InputText { text } | ContentItem::OutputText { text } => Ok(text.as_str()),
+            ContentItem::InputImage { .. } => {
+                Err(ChatCompletionsEncodingError::UnsupportedMessageContent {
+                    role: role.to_string(),
+                    content_type: "image",
+                })
+            }
+        })
+        .collect::<Result<Vec<_>, _>>()
+        .map(|parts| parts.join("\n"))
+}
+
+fn response_item_kind(item: &ResponseItem) -> &'static str {
+    match item {
+        ResponseItem::Message { .. } => "message",
+        ResponseItem::AgentMessage { .. } => "agent_message",
+        ResponseItem::Reasoning { .. } => "reasoning",
+        ResponseItem::LocalShellCall { .. } => "local_shell_call",
+        ResponseItem::FunctionCall { .. } => "function_call",
+        ResponseItem::ToolSearchCall { .. } => "tool_search_call",
+        ResponseItem::FunctionCallOutput { .. } => "function_call_output",
+        ResponseItem::CustomToolCall { .. } => "custom_tool_call",
+        ResponseItem::CustomToolCallOutput { .. } => "custom_tool_call_output",
+        ResponseItem::ToolSearchOutput { .. } => "tool_search_output",
+        ResponseItem::WebSearchCall { .. } => "web_search_call",
+        ResponseItem::ImageGenerationCall { .. } => "image_generation_call",
+        ResponseItem::Compaction { .. } => "compaction",
+        ResponseItem::CompactionTrigger => "compaction_trigger",
+        ResponseItem::ContextCompaction { .. } => "context_compaction",
+        ResponseItem::Other => "other",
+    }
+}
+
+#[cfg(test)]
+#[path = "chat_completions_tests.rs"]
+mod tests;
