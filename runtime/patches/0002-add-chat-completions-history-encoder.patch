+use crate::AdditionalProperties;
+use crate::JsonSchema;
+use crate::ToolSpec;
+use serde::Serialize;
+use thiserror::Error;
+
+#[derive(Debug, Clone, Serialize, PartialEq)]
+pub struct ChatCompletionsTool {
+    #[serde(rename = "type")]
+    pub kind: ChatCompletionsToolType,
+    pub function: ChatCompletionsFunctionTool,
+}
+
+#[derive(Debug, Clone, Copy, Serialize, PartialEq, Eq)]
+#[serde(rename_all = "lowercase")]
+pub enum ChatCompletionsToolType {
+    Function,
+}
+
+#[derive(Debug, Clone, Serialize, PartialEq)]
+pub struct ChatCompletionsFunctionTool {
+    pub name: String,
+    pub description: String,
+    pub parameters: JsonSchema,
+}
+
+#[derive(Debug, Error, PartialEq, Eq)]
+pub enum ChatCompletionsToolEncodingError {
+    #[error("chat completions does not support tool type: {0}")]
+    UnsupportedToolType(&'static str),
+}
+
+pub fn create_tools_for_chat_completions(
+    tools: &[ToolSpec],
+) -> Result<Vec<ChatCompletionsTool>, ChatCompletionsToolEncodingError> {
+    tools
+        .iter()
+        .map(|tool| match tool {
+            ToolSpec::Function(function) => Ok(ChatCompletionsTool {
+                kind: ChatCompletionsToolType::Function,
+                function: ChatCompletionsFunctionTool {
+                    name: function.name.clone(),
+                    description: function.description.clone(),
+                    parameters: parameters_without_responses_only_fields(&function.parameters),
+                },
+            }),
+            ToolSpec::Namespace(_) => Err(ChatCompletionsToolEncodingError::UnsupportedToolType(
+                "namespace",
+            )),
+            ToolSpec::ToolSearch { .. } => Err(
+                ChatCompletionsToolEncodingError::UnsupportedToolType("tool_search"),
+            ),
+            ToolSpec::ImageGeneration { .. } => Err(
+                ChatCompletionsToolEncodingError::UnsupportedToolType("image_generation"),
+            ),
+            ToolSpec::WebSearch { .. } => Err(
+                ChatCompletionsToolEncodingError::UnsupportedToolType("web_search"),
+            ),
+            ToolSpec::Freeform(_) => Err(ChatCompletionsToolEncodingError::UnsupportedToolType(
+                "custom",
+            )),
+        })
+        .collect()
+}
+
+fn parameters_without_responses_only_fields(parameters: &JsonSchema) -> JsonSchema {
+    let mut parameters = parameters.clone();
+    strip_responses_only_fields(&mut parameters);
+    parameters
+}
+
+fn strip_responses_only_fields(schema: &mut JsonSchema) {
+    schema.encrypted = None;
+
+    if let Some(items) = schema.items.as_mut() {
+        strip_responses_only_fields(items);
+    }
+    if let Some(properties) = schema.properties.as_mut() {
+        for property in properties.values_mut() {
+            strip_responses_only_fields(property);
+        }
+    }
+    if let Some(AdditionalProperties::Schema(additional_properties)) =
+        schema.additional_properties.as_mut()
+    {
+        strip_responses_only_fields(additional_properties);
+    }
+    for variants in [
+        schema.any_of.as_mut(),
+        schema.one_of.as_mut(),
+        schema.all_of.as_mut(),
+    ]
+    .into_iter()
+    .flatten()
+    {
+        for variant in variants {
+            strip_responses_only_fields(variant);
+        }
+    }
+    for definitions in [schema.defs.as_mut(), schema.definitions.as_mut()]
+        .into_iter()
+        .flatten()
+    {
+        for definition in definitions.values_mut() {
+            strip_responses_only_fields(definition);
+        }
+    }
+}
+
