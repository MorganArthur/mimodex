@@ -0,0 +1,321 @@
+use super::*;
+use assert_matches::assert_matches;
+use bytes::Bytes;
+use codex_client::TransportError;
+use futures::stream;
+use serde_json::json;
+
+fn idle_timeout() -> Duration {
+    Duration::from_secs(1)
+}
+
+async fn collect_events(chunks: Vec<Vec<u8>>) -> Vec<Result<ResponseEvent, ApiError>> {
+    let stream = stream::iter(
+        chunks
+            .into_iter()
+            .map(|chunk| Ok::<Bytes, TransportError>(Bytes::from(chunk))),
+    );
+    let (tx, mut rx) = mpsc::channel(64);
+    tokio::spawn(process_chat_completions_sse(
+        Box::pin(stream),
+        tx,
+        idle_timeout(),
+        None,
+    ));
+
+    let mut events = Vec::new();
+    while let Some(event) = rx.recv().await {
+        events.push(event);
+    }
+    events
+}
+
+fn split_irregularly(value: &str) -> Vec<Vec<u8>> {
+    let bytes = value.as_bytes();
+    let mut chunks = Vec::new();
+    let mut start = 0;
+    let mut width = 1;
+    while start < bytes.len() {
+        let end = (start + width).min(bytes.len());
+        chunks.push(bytes[start..end].to_vec());
+        start = end;
+        width = if width == 7 { 1 } else { width + 1 };
+    }
+    chunks
+}
+
+#[tokio::test]
+async fn parses_irregular_chunks_and_preserves_event_order() {
+    let body = [
+        format!(
+            "data: {}\n\n",
+            json!({
+                "id": "response-1",
+                "choices": [{
+                    "index": 0,
+                    "delta": {
+                        "reasoning_content": "先检查",
+                        "tool_calls": [{
+                            "index": 0,
+                            "id": "call-1",
+                            "type": "function",
+                            "function": {
+                                "name": "read_",
+                                "arguments": "{\"path\":\""
+                            }
+                        }]
+                    },
+                    "finish_reason": null
+                }]
+            })
+        ),
+        format!(
+            "data: {}\n\n",
+            json!({
+                "choices": [{
+                    "index": 0,
+                    "delta": {
+                        "reasoning_content": "文件",
+                        "tool_calls": [{
+                            "index": 0,
+                            "function": {
+                                "name": "fixture_file",
+                                "arguments": "src/math.ts\"}"
+                            }
+                        }]
+                    },
+                    "finish_reason": "tool_calls"
+                }],
+                "usage": {
+                    "prompt_tokens": 20,
+                    "completion_tokens": 22,
+                    "total_tokens": 42,
+                    "completion_tokens_details": {"reasoning_tokens": 12}
+                }
+            })
+        ),
+        "data: [DONE]\n\n".to_string(),
+    ]
+    .concat();
+
+    let events = collect_events(split_irregularly(&body)).await;
+    assert_eq!(events.len(), 9);
+    assert_matches!(events[0], Ok(ResponseEvent::Created));
+    assert_matches!(
+        &events[1],
+        Ok(ResponseEvent::OutputItemAdded(
+            ResponseItem::Reasoning { .. }
+        ))
+    );
+    assert_matches!(
+        &events[2],
+        Ok(ResponseEvent::ReasoningContentDelta { delta, content_index: 0 })
+            if delta == "先检查"
+    );
+    assert_matches!(
+        &events[3],
+        Ok(ResponseEvent::ToolCallInputDelta {
+            item_id,
+            call_id: Some(call_id),
+            delta,
+        }) if item_id == "call-1" && call_id == "call-1" && delta == "{\"path\":\""
+    );
+    assert_matches!(
+        &events[4],
+        Ok(ResponseEvent::ReasoningContentDelta { delta, content_index: 0 })
+            if delta == "文件"
+    );
+    assert_matches!(
+        &events[5],
+        Ok(ResponseEvent::ToolCallInputDelta { delta, .. }) if delta == "src/math.ts\"}"
+    );
+    assert_matches!(
+        &events[6],
+        Ok(ResponseEvent::OutputItemDone(ResponseItem::Reasoning { content, .. }))
+            if content.as_ref().is_some_and(|content| content == &vec![
+                ReasoningItemContent::ReasoningText {
+                    text: "先检查文件".to_string(),
+                }
+            ])
+    );
+    assert_matches!(
+        &events[7],
+        Ok(ResponseEvent::OutputItemDone(ResponseItem::FunctionCall {
+            name,
+            arguments,
+            call_id,
+            ..
+        })) if name == "read_fixture_file"
+            && arguments == "{\"path\":\"src/math.ts\"}"
+            && call_id == "call-1"
+    );
+    assert_matches!(
+        &events[8],
+        Ok(ResponseEvent::Completed {
+            response_id,
+            token_usage: Some(usage),
+            end_turn: Some(false),
+        }) if response_id == "response-1"
+            && usage.total_tokens == 42
+            && usage.reasoning_output_tokens == 12
+    );
+}
+
+#[tokio::test]
+async fn emits_text_message_before_stop_completion() {
+    let body = [
+        format!(
+            "data: {}\n\n",
+            json!({
+                "id": "response-2",
+                "choices": [{
+                    "index": 0,
+                    "delta": {"content": "完成"},
+                    "finish_reason": "stop"
+                }]
+            })
+        ),
+        "data: [DONE]\n\n".to_string(),
+    ]
+    .concat();
+
+    let events = collect_events(vec![body.into_bytes()]).await;
+    assert_matches!(events[0], Ok(ResponseEvent::Created));
+    assert_matches!(
+        &events[1],
+        Ok(ResponseEvent::OutputItemAdded(ResponseItem::Message { content, .. }))
+            if content.is_empty()
+    );
+    assert_matches!(
+        &events[2],
+        Ok(ResponseEvent::OutputTextDelta(delta)) if delta == "完成"
+    );
+    assert_matches!(
+        &events[3],
+        Ok(ResponseEvent::OutputItemDone(ResponseItem::Message { content, .. }))
+            if content == &vec![ContentItem::OutputText {
+                text: "完成".to_string(),
+            }]
+    );
+    assert_matches!(
+        &events[4],
+        Ok(ResponseEvent::Completed {
+            response_id,
+            end_turn: Some(true),
+            ..
+        }) if response_id == "response-2"
+    );
+}
+
+#[tokio::test]
+async fn finishes_reasoning_before_streaming_assistant_text() {
+    let body = [
+        format!(
+            "data: {}\n\n",
+            json!({
+                "id": "response-3",
+                "choices": [{
+                    "index": 0,
+                    "delta": {"reasoning_content": "思考"},
+                    "finish_reason": null
+                }]
+            })
+        ),
+        format!(
+            "data: {}\n\n",
+            json!({
+                "choices": [{
+                    "index": 0,
+                    "delta": {"content": "回答"},
+                    "finish_reason": "stop"
+                }]
+            })
+        ),
+        "data: [DONE]\n\n".to_string(),
+    ]
+    .concat();
+
+    let events = collect_events(vec![body.into_bytes()]).await;
+    assert_eq!(events.len(), 8);
+    assert_matches!(events[0], Ok(ResponseEvent::Created));
+    assert_matches!(
+        events[1],
+        Ok(ResponseEvent::OutputItemAdded(
+            ResponseItem::Reasoning { .. }
+        ))
+    );
+    assert_matches!(events[2], Ok(ResponseEvent::ReasoningContentDelta { .. }));
+    assert_matches!(
+        events[3],
+        Ok(ResponseEvent::OutputItemDone(
+            ResponseItem::Reasoning { .. }
+        ))
+    );
+    assert_matches!(
+        events[4],
+        Ok(ResponseEvent::OutputItemAdded(ResponseItem::Message { .. }))
+    );
+    assert_matches!(events[5], Ok(ResponseEvent::OutputTextDelta(_)));
+    assert_matches!(
+        events[6],
+        Ok(ResponseEvent::OutputItemDone(ResponseItem::Message { .. }))
+    );
+    assert_matches!(
+        events[7],
+        Ok(ResponseEvent::Completed {
+            end_turn: Some(true),
+            ..
+        })
+    );
+}
