+#[tokio::test]
+async fn rejects_invalid_or_incomplete_tool_calls() {
+    let invalid_json = [
+        format!(
+            "data: {}\n\n",
+            json!({
+                "id": "response-3",
+                "choices": [{
+                    "index": 0,
+                    "delta": {
+                        "tool_calls": [{
+                            "index": 0,
+                            "id": "call-1",
+                            "function": {"name": "read_file", "arguments": "{"}
+                        }]
+                    },
+                    "finish_reason": "tool_calls"
+                }]
+            })
+        ),
+        "data: [DONE]\n\n".to_string(),
+    ]
+    .concat();
+    let events = collect_events(vec![invalid_json.into_bytes()]).await;
+    assert_matches!(
+        events.last(),
+        Some(Err(ApiError::Stream(message))) if message.contains("invalid JSON arguments")
+    );
+
+    let arguments_before_id = format!(
+        "data: {}\n\n",
+        json!({
+            "choices": [{
+                "index": 0,
+                "delta": {
+                    "tool_calls": [{
+                        "index": 0,
+                        "function": {"arguments": "{}"}
+                    }]
+                },
+                "finish_reason": null
+            }]
+        })
+    );
+    let events = collect_events(vec![arguments_before_id.into_bytes()]).await;
+    assert_matches!(
+        events.last(),
+        Some(Err(ApiError::Stream(message))) if message.contains("before its id")
+    );
+}
