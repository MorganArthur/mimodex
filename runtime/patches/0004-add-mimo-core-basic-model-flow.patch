+use codex_models_manager::bundled_models_response;
+use codex_models_manager::model_info::BASE_INSTRUCTIONS;
+use codex_protocol::openai_models::ConfigShellToolType;
+use codex_protocol::openai_models::InputModality;
+use codex_protocol::openai_models::ModelInfo;
+use codex_protocol::openai_models::ModelVisibility;
+use codex_protocol::openai_models::ModelsResponse;
+
+pub(crate) const MIMO_DEFAULT_MODEL_ID: &str = "mimo-v2.5";
+pub(crate) const MIMO_PRO_MODEL_ID: &str = "mimo-v2.5-pro";
+const MIMO_CONTEXT_WINDOW: i64 = 1_000_000;
+const BASE_MODEL_ID: &str = "gpt-5.4";
+
+pub(crate) fn static_model_catalog() -> ModelsResponse {
+    ModelsResponse {
+        models: vec![
+            mimo_model(
+                MIMO_DEFAULT_MODEL_ID,
+                "MiMo v2.5",
+                "Default Mimodex model",
+                ModelVisibility::List,
+                /*priority*/ 0,
+            ),
+            mimo_model(
+                MIMO_PRO_MODEL_ID,
+                "MiMo v2.5 Pro",
+                "Advanced Mimodex model",
+                ModelVisibility::Hide,
+                /*priority*/ 1,
+            ),
+        ],
+    }
+}
+
+pub(crate) fn with_mimo_capabilities(mut catalog: ModelsResponse) -> ModelsResponse {
+    for model in &mut catalog.models {
+        apply_mimo_capabilities(model);
+    }
+    catalog
+}
+
+fn mimo_model(
+    slug: &str,
+    display_name: &str,
+    description: &str,
+    visibility: ModelVisibility,
+    priority: i32,
+) -> ModelInfo {
+    let mut model = bundled_models_response()
+        .unwrap_or_else(|error| panic!("bundled models.json should parse: {error}"))
+        .models
+        .into_iter()
+        .find(|model| model.slug == BASE_MODEL_ID)
+        .unwrap_or_else(|| panic!("bundled models.json should include {BASE_MODEL_ID}"));
+    model.slug = slug.to_string();
+    model.display_name = display_name.to_string();
+    model.description = Some(description.to_string());
+    model.visibility = visibility;
+    model.priority = priority;
+    apply_mimo_capabilities(&mut model);
+    model
+}
+
+fn apply_mimo_capabilities(model: &mut ModelInfo) {
+    model.default_reasoning_level = None;
+    model.supported_reasoning_levels.clear();
+    model.shell_type = ConfigShellToolType::Disabled;
+    model.additional_speed_tiers.clear();
+    model.service_tiers.clear();
+    model.default_service_tier = None;
+    model.base_instructions = BASE_INSTRUCTIONS.to_string();
+    model.model_messages = None;
+    model.supports_reasoning_summaries = false;
+    model.support_verbosity = false;
+    model.default_verbosity = None;
+    model.apply_patch_tool_type = None;
+    model.supports_parallel_tool_calls = false;
+    model.supports_image_detail_original = false;
+    model.context_window = Some(MIMO_CONTEXT_WINDOW);
+    model.max_context_window = Some(MIMO_CONTEXT_WINDOW);
+    model.effective_context_window_percent = 100;
+    model.auto_compact_token_limit = None;
+    model.experimental_supported_tools.clear();
+    model.input_modalities = vec![InputModality::Text];
+    model.supports_search_tool = false;
+    model.use_responses_lite = false;
+    model.auto_review_model_override = None;
+    model.tool_mode = None;
+    model.multi_agent_version = None;
+}
+
+#[cfg(test)]
+mod tests {
+    use codex_models_manager::manager::ModelsManager;
+    use codex_models_manager::manager::RefreshStrategy;
+    use codex_models_manager::manager::StaticModelsManager;
+    use pretty_assertions::assert_eq;
+
+    use super::*;
+
+    #[tokio::test]
+    async fn catalog_defaults_to_mimo_v2_5_and_hides_pro_from_normal_picker() {
+        let manager = StaticModelsManager::new(/*auth_manager*/ None, static_model_catalog());
+        let models = manager.list_models(RefreshStrategy::Offline).await;
+
+        assert_eq!(models.len(), 2);
+        assert_eq!(models[0].model, MIMO_DEFAULT_MODEL_ID);
+        assert!(models[0].is_default);
+        assert!(models[0].show_in_picker);
+        assert_eq!(models[1].model, MIMO_PRO_MODEL_ID);
+        assert!(!models[1].is_default);
+        assert!(!models[1].show_in_picker);
+    }
+
+    #[test]
+    fn catalog_disables_unverified_capabilities() {
+        for model in static_model_catalog().models {
+            assert_eq!(model.shell_type, ConfigShellToolType::Disabled);
+            assert!(!model.supports_reasoning_summaries);
+            assert!(!model.supports_parallel_tool_calls);
+            assert_eq!(model.input_modalities, vec![InputModality::Text]);
+            assert!(model.service_tiers.is_empty());
+            assert_eq!(model.context_window, Some(MIMO_CONTEXT_WINDOW));
+            assert_eq!(model.max_context_window, Some(MIMO_CONTEXT_WINDOW));
+            assert_eq!(model.effective_context_window_percent, 100);
+            assert_eq!(model.base_instructions, BASE_INSTRUCTIONS);
+        }
+    }
+}
