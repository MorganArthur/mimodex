+use std::sync::atomic::AtomicUsize;
+use std::sync::atomic::Ordering;
+
+use anyhow::Result;
+use codex_model_provider_info::MIMO_PROVIDER_ID;
+use codex_model_provider_info::ModelProviderInfo;
+use core_test_support::skip_if_no_network;
+use core_test_support::test_codex::TestCodexBuilder;
+use core_test_support::test_codex::test_codex;
+use pretty_assertions::assert_eq;
+use serde_json::Value;
+use serde_json::json;
+use wiremock::Mock;
+use wiremock::MockServer;
+use wiremock::Respond;
+use wiremock::ResponseTemplate;
+use wiremock::matchers::method;
+use wiremock::matchers::path;
+
+fn chat_sse(chunks: Vec<Value>) -> String {
+    chunks
+        .into_iter()
+        .map(|chunk| format!("data: {chunk}\n\n"))
+        .chain(std::iter::once("data: [DONE]\n\n".to_string()))
+        .collect()
+}
+
+async fn mount_chat_sse_sequence(server: &MockServer, bodies: Vec<String>) {
+    struct SequenceResponder {
+        calls: AtomicUsize,
+        bodies: Vec<String>,
+    }
+
+    impl Respond for SequenceResponder {
+        fn respond(&self, _: &wiremock::Request) -> ResponseTemplate {
+            let call = self.calls.fetch_add(1, Ordering::SeqCst);
+            let body = self
+                .bodies
+                .get(call)
+                .unwrap_or_else(|| panic!("no Chat Completions response for request {call}"));
+            ResponseTemplate::new(200)
+                .insert_header("content-type", "text/event-stream")
+                .set_body_string(body.clone())
+        }
+    }
+
+    let expected_calls = bodies.len() as u64;
+    Mock::given(method("POST"))
+        .and(path("/v1/chat/completions"))
+        .respond_with(SequenceResponder {
+            calls: AtomicUsize::new(0),
+            bodies,
+        })
+        .up_to_n_times(expected_calls)
+        .expect(expected_calls)
+        .mount(server)
+        .await;
+}
+
+fn mimo_test_builder(base_url: String) -> TestCodexBuilder {
+    test_codex()
+        .with_model("mimo-v2.5")
+        .with_config(move |config| {
+            let mut provider = ModelProviderInfo::create_mimo_provider();
+            provider.base_url = Some(base_url);
+            provider.env_http_headers = None;
+            provider.request_max_retries = Some(0);
+            provider.stream_max_retries = Some(0);
+            config.model_provider_id = MIMO_PROVIDER_ID.to_string();
+            config.model_provider = provider;
+        })
+}
+
+fn tool_call_response() -> String {
+    chat_sse(vec![json!({
+        "id": "chat-tool-1",
+        "choices": [{
+            "index": 0,
+            "delta": {
+                "reasoning_content": "需要运行命令",
+                "tool_calls": [{
+                    "index": 0,
+                    "id": "call-1",
+                    "type": "function",
+                    "function": {
+                        "name": "shell_command",
+                        "arguments": "{\"command\":\"echo mimo-tool-ok\"}"
+                    }
+                }]
+            },
+            "finish_reason": "tool_calls"
+        }]
+    })])
+}
+
+fn assistant_response(id: &str, content: &str) -> String {
+    chat_sse(vec![json!({
+        "id": id,
+        "choices": [{
+            "index": 0,
+            "delta": {"content": content},
+            "finish_reason": "stop"
+        }]
+    })])
+}
+
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn mimo_tool_loop_replays_reasoning_call_and_tool_output() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = MockServer::start().await;
+    mount_chat_sse_sequence(
+        &server,
+        vec![
+            tool_call_response(),
+            assistant_response("chat-tool-2", "工具执行完成"),
+        ],
+    )
+    .await;
+
+    let base_url = format!("{}/v1", server.uri());
+    let mut builder = mimo_test_builder(base_url);
+    let test = builder.build(&server).await?;
+
+    test.submit_turn("运行测试命令").await?;
+
+    let requests = server
+        .received_requests()
+        .await
+        .expect("mock server should expose requests");
+    assert_eq!(requests.len(), 2);
+    let first: Value =
+        serde_json::from_slice(&requests[0].body).expect("first request should be JSON");
+    let second: Value =
+        serde_json::from_slice(&requests[1].body).expect("second request should be JSON");
+
+    assert_eq!(first["model"], "mimo-v2.5");
+    assert!(
+        first["tools"]
+            .as_array()
+            .expect("tools should be an array")
+            .iter()
+            .any(|tool| tool["function"]["name"] == "shell_command")
+    );
+    let messages = second["messages"]
+        .as_array()
+        .expect("messages should be an array");
+    assert!(messages.iter().any(|message| {
+        message["role"] == "assistant"
+            && message["reasoning_content"] == "需要运行命令"
+            && message["tool_calls"][0]["id"] == "call-1"
+            && message["tool_calls"][0]["function"]["name"] == "shell_command"
+    }));
+    assert!(messages.iter().any(|message| {
+        message["role"] == "tool"
+            && message["tool_call_id"] == "call-1"
+            && message["content"]
+                .as_str()
+                .is_some_and(|content| content.contains("mimo-tool-ok"))
+    }));
+
+    Ok(())
+}
+
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn mimo_resume_replays_persisted_tool_history_and_continues() -> Result<()> {
+    skip_if_no_network!(Ok(()));
+
+    let server = MockServer::start().await;
+    mount_chat_sse_sequence(
+        &server,
+        vec![
+            tool_call_response(),
+            assistant_response("chat-before-resume", "初始轮次完成"),
+        ],
+    )
+    .await;
+
+    let base_url = format!("{}/v1", server.uri());
+    let mut builder = mimo_test_builder(base_url.clone());
+    let initial = builder.build(&server).await?;
+    initial.submit_turn("运行并记录测试命令").await?;
+    let home = initial.home.clone();
+    let rollout_path = initial
+        .session_configured
+        .rollout_path
+        .clone()
+        .expect("rollout path should exist");
+
+    mount_chat_sse_sequence(
+        &server,
+        vec![assistant_response("chat-after-resume", "恢复轮次完成")],
+    )
+    .await;
+    let mut resume_builder = mimo_test_builder(base_url);
+    let resumed = resume_builder.resume(&server, home, rollout_path).await?;
+    resumed.submit_turn("继续处理").await?;
+
+    let requests = server
+        .received_requests()
+        .await
+        .expect("mock server should expose requests");
+    assert_eq!(requests.len(), 3);
+    let resumed_request: Value =
+        serde_json::from_slice(&requests[2].body).expect("resumed request should be JSON");
+    let messages = resumed_request["messages"]
+        .as_array()
+        .expect("messages should be an array");
+    assert!(messages.iter().any(|message| {
+        message["role"] == "assistant"
+            && message["reasoning_content"] == "需要运行命令"
+            && message["tool_calls"][0]["id"] == "call-1"
+    }));
+    assert!(messages.iter().any(|message| {
+        message["role"] == "tool"
+            && message["tool_call_id"] == "call-1"
+            && message["content"]
+                .as_str()
+                .is_some_and(|content| content.contains("mimo-tool-ok"))
+    }));
+    assert!(messages.iter().any(|message| {
+        message["role"] == "assistant" && message["content"] == "初始轮次完成"
+    }));
+    assert!(
+        messages
+            .iter()
+            .any(|message| { message["role"] == "user" && message["content"] == "继续处理" })
+    );
+
+    Ok(())
+}
