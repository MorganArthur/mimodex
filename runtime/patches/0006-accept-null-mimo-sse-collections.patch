+#[tokio::test]
+async fn accepts_null_collections_from_mimo() {
+    let body = [
+        format!(
+            "data: {}\n\n",
+            json!({
+                "id": "response-null-collections",
+                "choices": null
+            })
+        ),
+        format!(
+            "data: {}\n\n",
+            json!({
+                "choices": [{
+                    "index": 0,
+                    "delta": {
+                        "content": "完成",
+                        "tool_calls": null
+                    },
+                    "finish_reason": "stop"
+                }]
+            })
+        ),
+        "data: [DONE]\n\n".to_string(),
+    ]
+    .concat();
+
+    let events = collect_events(vec![body.into_bytes()]).await;
+    assert_eq!(events.len(), 5);
+    assert_matches!(events[0], Ok(ResponseEvent::Created));
+    assert_matches!(
+        events[1],
+        Ok(ResponseEvent::OutputItemAdded(ResponseItem::Message { .. }))
+    );
+    assert_matches!(
+        &events[2],
+        Ok(ResponseEvent::OutputTextDelta(delta)) if delta == "完成"
+    );
+    assert_matches!(
+        events[4],
+        Ok(ResponseEvent::Completed {
+            end_turn: Some(true),
+            ..
+        })
+    );
+}
