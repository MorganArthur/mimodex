+fn should_include_chat_completions_tools(input: &[ResponseItem]) -> bool {
+    if input.iter().any(|item| {
+        matches!(
+            item,
+            ResponseItem::LocalShellCall { .. }
+                | ResponseItem::FunctionCall { .. }
+                | ResponseItem::FunctionCallOutput { .. }
+                | ResponseItem::CustomToolCall { .. }
+                | ResponseItem::CustomToolCallOutput { .. }
+                | ResponseItem::ToolSearchCall { .. }
+                | ResponseItem::ToolSearchOutput { .. }
+                | ResponseItem::WebSearchCall { .. }
+                | ResponseItem::ImageGenerationCall { .. }
+        )
+    }) {
+        return true;
+    }
+
+    let Some(latest_user_text) = input.iter().rev().find_map(|item| {
+        let ResponseItem::Message { role, content, .. } = item else {
+            return None;
+        };
+        if role != "user" {
+            return None;
+        }
+        Some(
+            content
+                .iter()
+                .filter_map(|item| match item {
+                    ContentItem::InputText { text } => Some(text.as_str()),
+                    _ => None,
+                })
+                .collect::<Vec<_>>()
+                .join("\n"),
+        )
+    }) else {
+        return true;
+    };
+
+    !is_simple_conversation(&latest_user_text)
+}
+
+fn is_simple_conversation(text: &str) -> bool {
+    let normalized = text
+        .to_lowercase()
+        .chars()
+        .filter(|character| {
+            !character.is_whitespace() && !".,?!;:，。？！；：".contains(*character)
+        })
+        .collect::<String>();
+
+    matches!(
+        normalized.as_str(),
+        "你好"
+            | "您好"
+            | "嗨"
+            | "哈喽"
+            | "你是谁"
+            | "你是什么模型"
+            | "你叫什么"
+            | "介绍一下你自己"
+            | "你能做什么"
+            | "谢谢"
+            | "感谢"
+            | "hi"
+            | "hello"
+            | "hey"
+            | "whoareyou"
+            | "whatmodelareyou"
+            | "whatcanyoudo"
+            | "thanks"
+            | "thankyou"
+    )
+}
