+#[test]
+fn chat_completions_skips_tools_for_simple_conversation() {
+    let client = test_model_client_with_wire_api(SessionSource::Exec, WireApi::ChatCompletions);
+    let prompt = Prompt {
+        input: vec![user_message("你是什么模型？")],
+        tools: vec![test_function_tool()],
+        ..Prompt::default()
+    };
+
+    let request = client
+        .build_chat_completions_request(&prompt, &test_model_info(), /*service_tier*/ None)
+        .expect("simple conversation request should build");
+
+    assert_eq!(request.get("tools"), None);
+    assert_eq!(request.get("tool_choice"), None);
+}
+
+#[test]
+fn chat_completions_keeps_tools_for_agent_tasks() {
+    let client = test_model_client_with_wire_api(SessionSource::Exec, WireApi::ChatCompletions);
+    let prompt = Prompt {
+        input: vec![user_message("创建一个 .gitignore 文件")],
+        tools: vec![test_function_tool()],
+        ..Prompt::default()
+    };
+
+    let request = client
+        .build_chat_completions_request(&prompt, &test_model_info(), /*service_tier*/ None)
+        .expect("agent task request should build");
+
+    assert_eq!(request["tool_choice"], json!("auto"));
+    assert_eq!(
+        request["tools"][0]["function"]["name"],
+        json!("shell_command")
+    );
+}
+
+fn user_message(text: &str) -> ResponseItem {
+    ResponseItem::Message {
+        id: None,
+        role: "user".to_string(),
+        content: vec![ContentItem::InputText {
+            text: text.to_string(),
+        }],
+        phase: None,
+    }
+}
+
+fn test_function_tool() -> ToolSpec {
+    ToolSpec::Function(ResponsesApiTool {
+        name: "shell_command".to_string(),
+        description: "Run a shell command".to_string(),
+        strict: false,
+        defer_loading: None,
+        parameters: JsonSchema::object(BTreeMap::new(), None, Some(false.into())),
+        output_schema: None,
+    })
+}
