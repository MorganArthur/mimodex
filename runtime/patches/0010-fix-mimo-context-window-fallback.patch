+#[test]
+fn mimo_fallback_metadata_uses_one_million_context_window() {
+    let model = model_info_from_slug("mimo-v2.5");
+
+    assert_eq!(model.context_window, Some(1_000_000));
+    assert_eq!(model.max_context_window, Some(1_000_000));
+    assert_eq!(model.effective_context_window_percent, 100);
+    assert!(!model.used_fallback_model_metadata);
+    assert!(model.base_instructions.contains("You are MiMo"));
+    assert!(
+        model
+            .base_instructions
+            .contains("1,000,000-token context window")
+    );
+    assert!(model.base_instructions.contains("UTF-8 encoding"));
+    assert!(
+        model
+            .base_instructions
+            .contains("syntax or compilation errors")
+    );
+    assert!(model.base_instructions.contains("AGENTS.md"));
+    assert!(
+        model
+            .base_instructions
+            .contains("never revert unrelated work")
+    );
+    assert!(!model.base_instructions.contains("Codex CLI"));
+}
